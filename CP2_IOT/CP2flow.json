  {
    "id": "mqtt_in_temp",
    "type": "mqtt in",
    "z": "tab_estufa",
    "name": "Recebe Temperatura",
    "topic": "estufa1/temperatura",
    "qos": "0",
    "datatype": "auto",
    "broker": "mqtt_broker_cfg",
    "x": 140,
    "y": 80,
    "wires": [["parse_temp"]]
  },
  {
    "id": "parse_temp",
    "type": "function",
    "z": "tab_estufa",
    "name": "Processa Temperatura",
    "func": "msg.payload = parseFloat(msg.payload);\nreturn msg;",
    "outputs": 1,
    "x": 370,
    "y": 80,
    "wires": [["gauge_temp", "chart_temp", "fn_sql_temp"]]
  },
  {
    "id": "gauge_temp",
    "type": "ui_gauge",
    "z": "tab_estufa",
    "name": "Gauge Temperatura",
    "group": "ui_group_sensores",
    "order": 1,
    "width": 6,
    "height": 4,
    "gtype": "gage",
    "title": "Temperatura (°C)",
    "label": "°C",
    "format": "{{value}}",
    "min": 0,
    "max": 60,
    "colors": ["#00b500", "#e6e600", "#ca3838"],
    "seg1": 30,
    "seg2": 40,
    "x": 620,
    "y": 40,
    "wires": []
  },
  {
    "id": "chart_temp",
    "type": "ui_chart",
    "z": "tab_estufa",
    "name": "Gráfico Temperatura",
    "group": "ui_group_sensores",
    "order": 3,
    "width": 12,
    "height": 4,
    "label": "Histórico Temperatura",
    "chartType": "line",
    "legend": "false",
    "xformat": "HH:mm:ss",
    "interpolate": "linear",
    "nodata": "",
    "dots": false,
    "ymin": 0,
    "ymax": 60,
    "removeOlder": 1,
    "removeOlderPoints": "100",
    "removeOlderUnit": "3600",
    "cutout": 0,
    "colors": ["#ff6b6b"],
    "x": 620,
    "y": 80,
    "wires": []
  },
  {
    "id": "fn_sql_temp",
    "type": "function",
    "z": "tab_estufa",
    "name": "Monta SQL Temp",
    "func": "var v = parseFloat(msg.payload);\nmsg.query = \"INSERT INTO leituras (sensor, valor, unidade) VALUES ('temperatura', \" + v + \", 'C')\";\nreturn msg;",
    "outputs": 1,
    "x": 610,
    "y": 120,
    "wires": [["oracledb_temp"]]
  },
  {
    "id": "oracledb_temp",
    "type": "oracledb",
    "z": "tab_estufa",
    "name": "Salva Temp Oracle",
    "server": "oracle_server_cfg",
    "x": 840,
    "y": 120,
    "wires": [[]]
  },

  {
    "id": "mqtt_in_hum",
