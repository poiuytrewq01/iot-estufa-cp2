    "nodata": "",
    "dots": false,
    "ymin": 0,
    "ymax": 100,
    "removeOlder": 1,
    "removeOlderPoints": "100",
    "removeOlderUnit": "3600",
    "cutout": 0,
    "colors": ["#4ecdc4"],
    "x": 620,
    "y": 220,
    "wires": []
  },
  {
    "id": "fn_sql_hum",
    "type": "function",
    "z": "tab_estufa",
    "name": "Monta SQL Umidade",
    "func": "var v = parseFloat(msg.payload);\nmsg.query = \"INSERT INTO leituras (sensor, valor, unidade) VALUES ('umidade', \" + v + \", '%')\";\nreturn msg;",
    "outputs": 1,
    "x": 610,
    "y": 260,
    "wires": [["oracledb_hum"]]
  },
  {
    "id": "oracledb_hum",
