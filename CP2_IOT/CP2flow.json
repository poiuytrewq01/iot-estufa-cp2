    "seg2": 70,
    "x": 620,
    "y": 180,
    "wires": []
  },
  {
    "id": "chart_hum",
    "type": "ui_chart",
    "z": "tab_estufa",
    "name": "Gráfico Umidade",
    "group": "ui_group_sensores",
    "order": 4,
    "width": 12,
    "height": 4,
    "label": "Histórico Umidade",
    "chartType": "line",
    "legend": "false",
    "xformat": "HH:mm:ss",
