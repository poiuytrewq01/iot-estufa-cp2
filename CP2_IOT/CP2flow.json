  {
    "id": "mqtt_in_alerta",
    "type": "mqtt in",
    "z": "tab_estufa",
    "name": "Recebe Alertas",
    "topic": "estufa1/alerta",
    "qos": "0",
    "datatype": "auto",
    "broker": "mqtt_broker_cfg",
    "x": 140,
    "y": 380,
    "wires": [["text_alerta", "fn_sql_alerta"]]
  },
  {
    "id": "text_alerta",
    "type": "ui_text",
    "z": "tab_estufa",
    "group": "ui_group_alertas",
    "order": 1,
    "width": 12,
    "height": 1,
    "name": "Painel de Alertas",
    "label": "⚠ Último Alerta:",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "x": 380,
    "y": 360,
    "wires": []
  },
  {
    "id": "fn_sql_alerta",
    "type": "function",
    "z": "tab_estufa",
    "name": "Monta SQL Alerta",
    "func": "var m = msg.payload.replace(/'/g, '');\nmsg.query = \"INSERT INTO alertas (mensagem) VALUES ('\" + m + \"')\";\nreturn msg;",
    "outputs": 1,
    "x": 380,
    "y": 400,
    "wires": [["oracledb_alerta"]]
  },
  {
    "id": "oracledb_alerta",
    "type": "oracledb",
    "z": "tab_estufa",
    "name": "Salva Alerta Oracle",
    "server": "oracle_server_cfg",
    "x": 620,
    "y": 400,
    "wires": [[]]
  },

  {
    "id": "inject_clima",
    "type": "inject",
    "z": "tab_estufa",
    "name": "A cada 10 min",
    "repeat": "600",
    "crontab": "",
    "once": true,
    "onceDelay": 2,
    "topic": "",
    "payload": "",
    "x": 140,
    "y": 520,
    "wires": [["http_openweather"]]
  },
  {
    "id": "http_openweather",
    "type": "http request",
    "z": "tab_estufa",
    "name": "OpenWeather API",
    "method": "GET",
    "ret": "obj",
    "url": "https://api.openweathermap.org/data/2.5/weather?q=Sao Paulo,BR&appid=SUA_API_KEY_AQUI&units=metric&lang=pt_br",
    "x": 360,
    "y": 520,
    "wires": [["parse_clima"]]
  },
  {
    "id": "parse_clima",
    "type": "function",
    "z": "tab_estufa",
    "name": "Extrai dados clima",
    "func": "var d = msg.payload;\nmsg.cidade    = d.name;\nmsg.temp_ext  = d.main.temp;\nmsg.hum_ext   = d.main.humidity;\nmsg.descricao = d.weather[0].description;\nmsg.sensacao  = d.main.feels_like;\nreturn msg;",
    "outputs": 1,
    "x": 580,
    "y": 520,
    "wires": [["ch_cidade","ch_temp_ext","ch_hum_ext","ch_descricao","ch_sensacao"]]
  },
  {
    "id": "ch_cidade",
    "type": "change",
    "z": "tab_estufa",
    "name": "",
    "rules": [{"t":"set","p":"payload","pt":"msg","to":"cidade","tot":"msg"}],
    "x": 790,
    "y": 460,
    "wires": [["text_cidade"]]
  },
  {
    "id": "ch_temp_ext",
    "type": "change",
    "z": "tab_estufa",
    "name": "",
    "rules": [{"t":"set","p":"payload","pt":"msg","to":"temp_ext","tot":"msg"}],
    "x": 790,
    "y": 500,
    "wires": [["text_temp_ext"]]
  },
  {
    "id": "ch_hum_ext",
    "type": "change",
    "z": "tab_estufa",
    "name": "",
    "rules": [{"t":"set","p":"payload","pt":"msg","to":"hum_ext","tot":"msg"}],
    "x": 790,
    "y": 540,
    "wires": [["text_hum_ext"]]
  },
  {
    "id": "ch_descricao",
    "type": "change",
    "z": "tab_estufa",
    "name": "",
    "rules": [{"t":"set","p":"payload","pt":"msg","to":"descricao","tot":"msg"}],
    "x": 790,
